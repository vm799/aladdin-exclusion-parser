# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=4096

# Aladdin SDK Configuration
ASDK_USER_CONFIG_FILE=/path/to/aladdin/config.yaml
ALADDIN_API_KEY=your-aladdin-api-key
ALADDIN_API_BASE=https://api.aladdin.com/v1
ALADDIN_ENVIRONMENT=test  # test or production

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aladdin_parser
DATABASE_ECHO=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Development
DEBUG=false
ENVIRONMENT=development  # development, staging, production
